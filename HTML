/* --- tree --- */
function handleTree(tab) {
    const node = getNode(tab.cwd);
    if (!node || node.type !== 'dir') return '<span class="error-line">Not a directory</span>';
    let lines = [`<span style="color:var(--blue)">.</span>`];
    let dirCount = 0, fileCount = 0;
    function walk(n, prefix) {
        const entries = Object.entries(n.children).filter(([name]) => !name.startsWith('.'));
        entries.forEach(([name, child], i) => {
            const isLast = i === entries.length - 1;
            const connector = isLast ? '└── ' : '├── ';
            const color = child.type === 'dir' ? 'var(--blue)' : 'var(--text)';
            lines.push(`${prefix}${connector}<span style="color:${color}">${escapeHtml(name)}${child.type === 'dir' ? '/' : ''}</span>`);
            if (child.type === 'dir') {
                dirCount++;
                walk(child, prefix + (isLast ? '    ' : '│   '));
            } else {
                fileCount++;
            }
        });
    }
    walk(node, '');
    lines.push('');
    lines.push(`<span class="dim-line">${dirCount} directories, ${fileCount} files</span>`);
    return lines.join('\n');
}

/* --- wc --- */
function handleWc(args, tab) {
    const resolved = resolvePath(args[args.length - 1], tab.cwd);
    const node = getNode(resolved);
    if (!node || node.type !== 'file') return `<span class="error-line">wc: ${escapeHtml(args[args.length - 1])}: No such file</span>`;
    const c = node.content;
    const lines = c.split('\n').length;
    const words = c.split(/\s+/).filter(Boolean).length;
    const chars = c.length;
    return `  ${String(lines).padStart(6)} ${String(words).padStart(6)} ${String(chars).padStart(6)} ${escapeHtml(args[args.length - 1])}`;
}

/* --- head --- */
function handleHead(args, tab) {
    const file = args[args.length - 1];
    const n = args.includes('-n') ? parseInt(args[args.indexOf('-n') + 1]) || 10 : 10;
    const resolved = resolvePath(file, tab.cwd);
    const node = getNode(resolved);
    if (!node || node.type !== 'file') return `<span class="error-line">head: ${escapeHtml(file)}: No such file</span>`;
    return escapeHtml(node.content.split('\n').slice(0, n).join('\n'));
}

/* --- clear --- */
function clearScreen(tabId) {
    const screen = document.querySelector(`.screen[data-id="${tabId}"]`);
    if (!screen) return;
    screen.innerHTML = '';
    createInputLine(screen, tabId);
}

/* ============================================================
   هندل کردن ورودی
   ============================================================ */
function handleKeyDown(e, tabId) {
    const tab = terminals[tabId];
    const screen = document.querySelector(`.screen[data-id="${tabId}"]`);
    const input = e.target;

    if (e.key === 'Enter') {
        e.preventDefault();
        const cmdText = input.value;

        /* جایگزینی خط ورودی با خط ثابت */
        const inputLine = screen.querySelector('.input-line');
        const cmdLine = document.createElement('div');
        cmdLine.className = 'line command-line';
        cmdLine.innerHTML = getPrompt(tab) + `<span class="command-text">${escapeHtml(cmdText)}</span>`;
        inputLine.replaceWith(cmdLine);

        if (cmdText.trim()) {
            tab.history.push(cmdText.trim());
            tab.historyIndex = tab.history.length;
            const output = processCommand(cmdText.trim(), tab);
            if (output !== null && output !== undefined) {
                addOutputLines(screen, output, output.includes('error-line') ? 'error-line' : '');
            }
        }

        /* آپدیت نوار وضعیت */
        document.getElementById('statusCwd').textContent = displayPath(tab.cwd);

        createInputLine(screen, tabId);
        screen.scrollTop = screen.scrollHeight;

    } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (tab.historyIndex > 0) {
            tab.historyIndex--;
            input.value = tab.history[tab.historyIndex];
        }

    } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (tab.historyIndex < tab.history.length - 1) {
            tab.historyIndex++;
            input.value = tab.history[tab.historyIndex];
        } else {
            tab.historyIndex = tab.history.length;
            input.value = '';
        }

    } else if (e.key === 'l' && e.ctrlKey) {
        e.preventDefault();
        clearScreen(tabId);
    }
}

/* ============================================================
   ساعت
   ============================================================ */
function updateClock() {
    const now = new Date();
    document.getElementById('clock').textContent = now.toLocaleTimeString('en-US', { hour12: false });
}

/* ============================================================
   مقداردهی اولیه
   ============================================================ */
function init() {
    /* دکمه اضافه کردن تب */
    const addBtn = document.createElement('button');
    addBtn.className = 'add-tab-btn';
    addBtn.innerHTML = '<i class="fas fa-plus"></i>';
    addBtn.title = 'New Terminal';
    addBtn.addEventListener('click', () => {
        const num = Object.keys(terminals).length + 1;
        createTerminal(`runner@ubuntu-${num}`);
    });
    document.getElementById('tabBar').appendChild(addBtn);

    /* دکمه close در نوار عنوان */
    document.getElementById('btnClose').addEventListener('click', () => {
        if (activeTabId) closeTab(activeTabId);
    });

    /* ساخت اولین تب */
    createTerminal('runner@ubuntu');

    /* شروع ساعت */
    updateClock();
    setInterval(updateClock, 1000);
}

init();
