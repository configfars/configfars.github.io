        'mv':         () => args.length >= 2 ? '' : '<span class="error-line">mv: missing operand</span>',
    };

    if (handlers[cmd]) return handlers[cmd]();
    return `<span class="error-line">bash: ${escapeHtml(cmd)}: command not found</span>`;
}

/* --- ls --- */
function handleLs(args, tab) {
    const showAll = args.includes('-a') || args.includes('-la') || args.includes('-al');
    const longFormat = args.includes('-l') || args.includes('-la') || args.includes('-al');
    const target = args.find(a => !a.startsWith('-')) || '.';
    const resolved = resolvePath(target, tab.cwd);
    const node = getNode(resolved);
    if (!node) return `<span class="error-line">ls: cannot access '${escapeHtml(target)}': No such file or directory</span>`;
    if (node.type !== 'dir') return escapeHtml(target);

    const entries = Object.entries(node.children);
    if (!longFormat) {
        /* فرمت کوتاه */
        let items = entries.map(([name, n]) => {
            if (!showAll && name.startsWith('.')) return null;
            const color = n.type === 'dir' ? 'var(--blue)' : (name.endsWith('.sh') ? 'var(--green)' : 'var(--text)');
            return `<span style="color:${color}">${escapeHtml(name)}${n.type === 'dir' ? '/' : ''}</span>`;
        }).filter(Boolean);
        return items.join('  ') || '<span class="dim-line">(empty)</span>';
    }

    /* فرمت طولانی -la */
    let lines = [`total ${entries.length * 4 + 12}`];
    if (showAll) {
        lines.push(`drwxr-xr-x  ${entries.length + 2} runner runner 4096 Jan 15 10:30 <span style="color:var(--blue)">.</span>`);
        lines.push(`drwxr-xr-x  ${entries.length + 2} runner runner 4096 Jan 15 10:30 <span style="color:var(--blue)">..</span>`);
    }
    entries.forEach(([name, n]) => {
        if (!showAll && name.startsWith('.')) return;
        const isDir = n.type === 'dir';
        const perm = isDir ? 'drwxr-xr-x' : (name.endsWith('.sh') ? '-rwxr-xr-x' : '-rw-r--r--');
        const links = isDir ? String(Math.floor(Math.random() * 4) + 2).padStart(2) : ' 1';
        const size = isDir ? ' 4096' : String(n.content.length).padStart(5);
        const color = isDir ? 'var(--blue)' : (name.endsWith('.sh') ? 'var(--green)' : 'var(--text)');
        lines.push(`${perm} ${links} runner runner${size} Jan 15 10:30 <span style="color:${color}">${escapeHtml(name)}${isDir ? '/' : ''}</span>`);
    });
    return lines.length === 1 ? '<span class="dim-line">(empty)</span>' : lines.join('\n');
}

/* --- cd --- */
function handleCd(args, tab) {
    const target = args[0] || '~';
    const resolved = resolvePath(target, tab.cwd);
    const node = getNode(resolved);
    if (!node) return `<span class="error-line">bash: cd: ${escapeHtml(target)}: No such file or directory</span>`;
    if (node.type !== 'dir') return `<span class="error-line">bash: cd: ${escapeHtml(target)}: Not a directory</span>`;
    tab.cwd = resolved;
    document.getElementById('statusCwd').textContent = displayPath(tab.cwd);
    return '';
}

/* --- cat --- */
function handleCat(args, tab) {
    if (!args[0]) return `<span class="error-line">cat: missing operand</span>`;
    const resolved = resolvePath(args[0], tab.cwd);
    const node = getNode(resolved);
    if (!node) return `<span class="error-line">cat: ${escapeHtml(args[0])}: No such file or directory</span>`;
    if (node.type === 'dir') return `<span class="error-line">cat: ${escapeHtml(args[0])}: Is a directory</span>`;
    return escapeHtml(node.content);
}

/* --- echo --- */
function handleEcho(args) {
    return escapeHtml(args.join(' ').replace(/^["']|["']$/g, ''));
}

/* --- mkdir --- */
function handleMkdir(args, tab) {
    if (!args[0]) return `<span class="error-line">mkdir: missing operand</span>`;
    const resolved = resolvePath(args[0], tab.cwd);
    const parts = resolved.split('/').filter(Boolean);
    const dirName = parts.pop();
    const parentPath = '/' + parts.join('/');
    const parent = getNode(parentPath);
    if (!parent || parent.type !== 'dir') return `<span class="error-line">mkdir: cannot create directory '${escapeHtml(args[0])}': No such file or directory</span>`;
    if (parent.children[dirName]) return `<span class="error-line">mkdir: cannot create directory '${escapeHtml(args[0])}': File exists</span>`;
    parent.children[dirName] = { type: 'dir', children: {} };
    return '';
}

/* --- touch --- */
function handleTouch(args, tab) {
    if (!args[0]) return `<span class="error-line">touch: missing operand</span>`;
    const resolved = resolvePath(args[0], tab.cwd);
    const parts = resolved.split('/').filter(Boolean);
    const fileName = parts.pop();
    const parentPath = '/' + parts.join('/');
    const parent = getNode(parentPath);
    if (!parent || parent.type !== 'dir') return `<span class="error-line">touch: cannot touch '${escapeHtml(args[0])}': No such file or directory</span>`;
    if (!parent.children[fileName]) parent.children[fileName] = { type: 'file', content: '' };
    return '';
}

/* --- rm --- */
function handleRm(args, tab) {
    if (!args.find(a => !a.startsWith('-'))) return `<span class="error-line">rm: missing operand</span>`;
    const target = args.find(a => !a.startsWith('-'));
    const recursive = args.includes('-r') || args.includes('-rf') || args.includes('-fr');
    const resolved = resolvePath(target, tab.cwd);
    const parts = resolved.split('/').filter(Boolean);
    const name = parts.pop();
    const parentPath = '/' + parts.join('/');
    const parent = getNode(parentPath);
    if (!parent || parent.type !== 'dir' || !parent.children[name]) return `<span class="error-line">rm: cannot remove '${escapeHtml(target)}': No such file or directory</span>`;
    if (parent.children[name].type === 'dir' && !recursive) return `<span class="error-line">rm: cannot remove '${escapeHtml(target)}': Is a directory</span>`;
    delete parent.children[name];
    return '';
}

/* --- uname --- */
function handleUname(args) {
    if (args.includes('-a')) return 'Linux ubuntu 5.15.0-91-generic #101-Ubuntu SMP Tue Nov 14 14:19:04 UTC 2023 x86_64 GNU/Linux';
    if (args.includes('-r')) return '5.15.0-91-generic';
    if (args.includes('-s')) return 'Linux';
    if (args.includes('-n')) return 'ubuntu';
    if (args.includes('-m')) return 'x86_64';
    return 'Linux';
}

