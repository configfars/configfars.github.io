<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ubuntu Terminal</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root {
    --bg-deep: #050a10;
    --bg: #0a0e14;
    --surface: #0d1117;
    --surface-2: #151b23;
    --border: #21262d;
    --text: #e6edf3;
    --text-dim: #6e7681;
    --green: #00ff88;
    --green-dim: rgba(0,255,136,0.12);
    --green-glow: rgba(0,255,136,0.08);
    --red: #ff5f57;
    --yellow: #febc2e;
    --green-btn: #28c840;
    --blue: #58a6ff;
    --orange: #E95420;
    --purple: #bc8cff;
    --pink: #f778ba;
    --cyan: #39d2e6;
    --font: 'JetBrains Mono', monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{
    background:var(--bg-deep);
    font-family:var(--font);
    color:var(--text);
    display:flex;
    justify-content:center;
    align-items:center;
}

/* === انیمیشن پس‌زمینه === */
.bg-blob{
    position:fixed;
    border-radius:50%;
    filter:blur(120px);
    pointer-events:none;
    z-index:0;
}
.blob-1{
    width:500px;height:500px;
    background:var(--green);
    opacity:0.06;
    top:-150px;left:-100px;
    animation:blobFloat 25s ease-in-out infinite alternate;
}
.blob-2{
    width:400px;height:400px;
    background:var(--blue);
    opacity:0.04;
    bottom:-120px;right:-80px;
    animation:blobFloat 20s ease-in-out infinite alternate-reverse;
}
.blob-3{
    width:300px;height:300px;
    background:var(--purple);
    opacity:0.035;
    top:40%;left:60%;
    animation:blobFloat 30s ease-in-out infinite alternate;
    animation-delay:-10s;
}
@keyframes blobFloat{
    0%{transform:translate(0,0) scale(1)}
    33%{transform:translate(40px,-30px) scale(1.1)}
    66%{transform:translate(-20px,50px) scale(0.95)}
    100%{transform:translate(30px,20px) scale(1.05)}
}

/* === کانتینر ترمینال === */
.terminal-wrapper{
    position:relative;
    z-index:1;
    width:94%;
    max-width:1020px;
    height:88vh;
    max-height:740px;
}
.terminal{
    width:100%;
    height:100%;
    display:flex;
    flex-direction:column;
    background:var(--bg);
    border-radius:14px;
    border:1px solid var(--border);
    overflow:hidden;
    position:relative;
    animation:terminalGlow 5s ease-in-out infinite alternate;
}
@keyframes terminalGlow{
    0%{box-shadow:0 0 20px var(--green-glow),0 4px 60px rgba(0,0,0,0.5)}
    100%{box-shadow:0 0 40px rgba(0,255,136,0.14),0 4px 80px rgba(0,0,0,0.6)}
}

/* === نوار عنوان === */
.title-bar{
    display:flex;
    align-items:center;
    padding:12px 16px;
    background:var(--surface);
    border-bottom:1px solid var(--border);
    gap:12px;
    user-select:none;
    flex-shrink:0;
}
.traffic-lights{
    display:flex;
    gap:8px;
}
.tl{
    width:13px;height:13px;
    border-radius:50%;
    cursor:pointer;
    transition:filter 0.2s,transform 0.15s;
    position:relative;
}
.tl:hover{filter:brightness(1.3);transform:scale(1.15)}
.tl-red{background:var(--red)}
.tl-yellow{background:var(--yellow)}
.tl-green-btn{background:var(--green-btn)}
.title-text{
    flex:1;
    text-align:center;
    font-size:12px;
    font-weight:500;
    color:var(--text-dim);
    letter-spacing:0.5px;
}
.title-spacer{width:55px}

/* === نوار تب‌ها === */
.tab-bar{
    display:flex;
    align-items:stretch;
    background:var(--surface);
    border-bottom:1px solid var(--border);
    padding:0 8px;
    gap:2px;
    flex-shrink:0;
    overflow-x:auto;
    scrollbar-width:none;
}
.tab-bar::-webkit-scrollbar{display:none}
.tab{
    display:flex;
    align-items:center;
    gap:8px;
    padding:9px 14px;
    font-size:11.5px;
    color:var(--text-dim);
    cursor:pointer;
    border-radius:8px 8px 0 0;
    position:relative;
    transition:all 0.2s;
    white-space:nowrap;
    user-select:none;
    flex-shrink:0;
}
.tab:hover{color:var(--text);background:rgba(255,255,255,0.04)}
.tab.active{color:var(--green);background:var(--surface-2)}
.tab.active::after{
    content:'';position:absolute;
    bottom:0;left:8px;right:8px;
    height:2px;
    background:var(--green);
    border-radius:2px 2px 0 0;
}
.tab-icon{font-size:11px;opacity:0.7}
.tab-close{
    display:none;
    font-size:15px;
    line-height:1;
    opacity:0.4;
    padding:0 2px;
    border-radius:4px;
    transition:all 0.15s;
}
.tab:hover .tab-close{display:inline}
.tab-close:hover{opacity:1;background:rgba(255,95,87,0.2);color:var(--red)}
.add-tab-btn{
    display:flex;
    align-items:center;
    justify-content:center;
    width:30px;height:30px;
    margin:auto 4px;
    background:none;
    border:1px solid transparent;
    color:var(--text-dim);
    cursor:pointer;
    border-radius:6px;
    transition:all 0.2s;
    font-size:12px;
    flex-shrink:0;
}
.add-tab-btn:hover{
    color:var(--green);
    background:var(--green-dim);
    border-color:rgba(0,255,136,0.15);
}

/* === محتوای ترمینال === */
.screen-container{
    position:relative;
    flex:1;
    overflow:hidden;
}
.screen{
    position:absolute;
    inset:0;
    padding:16px 18px;
    overflow-y:auto;
    font-size:13px;
    line-height:1.7;
    display:none;
    cursor:text;
}
.screen.active{display:block}
.screen:focus{outline:none}

/* === خطوط خروجی === */
.line{white-space:pre-wrap;word-break:break-all}
.output-line{color:var(--text)}
.error-line{color:var(--red)}
.dim-line{color:var(--text-dim)}
.success-line{color:var(--green)}
.info-line{color:var(--blue)}
.neofetch-line{line-height:1.5}

/* === پرامپت === */
.prompt-user{color:var(--green);font-weight:700}
.prompt-sep{color:var(--text-dim)}
.prompt-host{color:var(--green);font-weight:700}
.prompt-path{color:var(--blue);font-weight:500}
.prompt-dollar{color:var(--green)}
.command-text{color:var(--text)}

/* === خط ورودی === */
.input-line{
    display:flex;
    align-items:center;
    margin-top:1px;
}
.input-field{
    flex:1;
    background:none;
    border:none;
    outline:none;
    color:var(--text);
    font-family:var(--font);
    font-size:13px;
    line-height:1.7;
    caret-color:var(--green);
    padding:0;
}

/* === نوار وضعیت === */
.status-bar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:5px 16px;
    background:var(--surface);
    border-top:1px solid var(--border);
    font-size:10.5px;
    color:var(--text-dim);
    flex-shrink:0;
    gap:12px;
}
.status-bar .status-left,
.status-bar .status-right{
    display:flex;align-items:center;gap:14px;
}
.status-bar .connected{color:var(--green)}
.status-bar .dot{
    display:inline-block;
    width:6px;height:6px;
    border-radius:50%;
    background:var(--green);
    animation:pulse 2s ease-in-out infinite;
}
@keyframes pulse{
    0%,100%{opacity:1}50%{opacity:0.3}
}

/* === افکت CRT === */
.crt-overlay{
    position:absolute;
    inset:0;
    pointer-events:none;
    z-index:10;
    background:repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.025) 2px,
        rgba(0,0,0,0.025) 4px
    );
    border-radius:14px;
}
.crt-vignette{
    position:absolute;
    inset:0;
    pointer-events:none;
    z-index:11;
    border-radius:14px;
    background:radial-gradient(ellipse at center,transparent 60%,rgba(0,0,0,0.3) 100%);
}

/* === اسکرول‌بار سفارشی === */
.screen::-webkit-scrollbar{width:6px}
.screen::-webkit-scrollbar-track{background:transparent}
.screen::-webkit-scrollbar-thumb{
    background:rgba(255,255,255,0.1);
    border-radius:3px;
}
.screen::-webkit-scrollbar-thumb:hover{background:rgba(255,255,255,0.2)}

/* === ریسپانسیو === */
@media(max-width:640px){
    .terminal-wrapper{width:98%;height:92vh;max-height:none}
    .screen{padding:10px 12px;font-size:12px}
    .title-text{display:none}
    .title-spacer{width:auto}
    .tab{padding:7px 10px;font-size:10.5px}
}

/* === ترجیحات حرکتی کاهش‌یافته === */
@media(prefers-reduced-motion:reduce){
    *,*::before,*::after{
        animation-duration:0.01ms!important;
        transition-duration:0.01ms!important;
    }
}
</style>
</head>
<body>

<!-- بلاب‌های پس‌زمینه -->
<div class="bg-blob blob-1"></div>
<div class="bg-blob blob-2"></div>
<div class="bg-blob blob-3"></div>

<div class="terminal-wrapper">
<div class="terminal">

    <!-- نوار عنوان -->
    <div class="title-bar">
        <div class="traffic-lights">
            <span class="tl tl-red" id="btnClose" title="Close"></span>
            <span class="tl tl-yellow" title="Minimize"></span>
            <span class="tl tl-green-btn" title="Maximize"></span>
        </div>
        <span class="title-text">Ubuntu Terminal — bash</span>
        <span class="title-spacer"></span>
    </div>

    <!-- نوار تب‌ها -->
    <div class="tab-bar" id="tabBar"></div>

    <!-- محتوای ترمینال -->
    <div class="screen-container" id="screenContainer"></div>

    <!-- نوار وضعیت -->
    <div class="status-bar">
        <div class="status-left">
            <span class="connected"><span class="dot"></span> Connected</span>
            <span><i class="fas fa-terminal" style="font-size:9px"></i> bash</span>
        </div>
        <div class="status-right">
            <span id="statusCwd">~</span>
            <span id="clock">00:00:00</span>
        </div>
    </div>

    <!-- افکت‌های CRT -->
    <div class="crt-overlay"></div>
    <div class="crt-vignette"></div>

</div>
</div>

<script>
/* ============================================================
   مدیریت وضعیت ترمینال‌ها
   ============================================================ */
let tabCounter = 0;
const terminals = {};
let activeTabId = null;

/* ============================================================
   فایل‌سیستم شبیه‌سازی‌شده
   ============================================================ */
const HOME = '/home/runner';

const fileSystem = {
    type: 'dir', children: {
        home: { type: 'dir', children: {
            runner: { type: 'dir', children: {
                Documents: { type: 'dir', children: {
                    'readme.md': { type: 'file', content: '# Ubuntu Web Terminal\nA fully simulated Linux terminal experience.\n\n## Features\n- Multi-tab support\n- Simulated filesystem\n- Command history\n- neofetch display' },
                    'notes.txt': { type: 'file', content: 'TODO: Update nginx config\nTODO: Renew SSL certificate\nTODO: Backup database before migration' },
                    projects: { type: 'dir', children: {
                        'web-app': { type: 'dir', children: {
                            'index.html': { type: 'file', content: '<!DOCTYPE html>\n<html>\n<head><title>My App</title></head>\n<body><h1>Hello World</h1></body>\n</html>' },
                            'style.css': { type: 'file', content: 'body {\n  margin: 0;\n  font-family: sans-serif;\n  background: #1a1a2e;\n  color: #eee;\n}' },
                            'app.js': { type: 'file', content: 'const app = {\n  init() {\n    console.log("App initialized");\n  }\n};\n\napp.init();' },
                        }},
                        'api-server': { type: 'dir', children: {
                            'server.js': { type: 'file', content: 'const http = require("http");\n\nhttp.createServer((req, res) => {\n  res.writeHead(200);\n  res.end("OK");\n}).listen(3000);\n\nconsole.log("Server running on :3000");' },
                            'package.json': { type: 'file', content: '{\n  "name": "api-server",\n  "version": "1.0.0",\n  "main": "server.js",\n  "scripts": {\n    "start": "node server.js"\n  }\n}' },
                        }},
                    }},
                }},
                Downloads: { type: 'dir', children: {
                    'archive.tar.gz': { type: 'file', content: '[binary data — 2.4 MB]' },
                    'setup.sh': { type: 'file', content: '#!/bin/bash\nset -e\necho "Setting up environment..."\napt update -qq\napt install -y -qq build-essential\necho "Done."' },
                    'data.csv': { type: 'file', content: 'id,name,value\n1,alpha,100\n2,beta,200\n3,gamma,300\n4,delta,400\n5,epsilon,500' },
                }},
                '.bashrc': { type: 'file', content: '# ~/.bashrc\nexport PATH="$PATH:/usr/local/bin"\nexport EDITOR=vim\nalias ll="ls -la"\nalias cls="clear"\nalias gs="git status"' },
                '.ssh': { type: 'dir', children: {
                    'authorized_keys': { type: 'file', content: 'ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABgQC7V... user@workstation' },
                    'known_hosts': { type: 'file', content: 'github.com ssh-rsa AAAAB3NzaC1yc2EAAAA...\ngitlab.com ssh-ed25519 AAAAC3NzaC1lZDI1...' },
                }},
                '.gitconfig': { type: 'file', content: '[user]\n    name = Runner\n    email = runner@ubuntu\n[core]\n    editor = vim\n    autocrlf = input\n[color]\n    ui = auto' },
                Pictures: { type: 'dir', children: {
                    'screenshot.png': { type: 'file', content: '[image data — 847 KB]' },
                    'wallpaper.jpg': { type: 'file', content: '[image data — 3.2 MB]' },
                }},
                Desktop: { type: 'dir', children: {} },
                Music: { type: 'dir', children: {} },
            }}
        }}
    }
};

/* ============================================================
   توابع کمکی
   ============================================================ */
function escapeHtml(t) {
    const d = document.createElement('div');
    d.textContent = t;
    return d.innerHTML;
}

/* حل کردن مسیر نسبت به مسیر فعلی */
function resolvePath(p, cwd) {
    if (!p || p === '~') return HOME;
    if (p.startsWith('~/')) p = HOME + p.slice(1);
    if (!p.startsWith('/')) p = cwd + '/' + p;
    const parts = p.split('/').filter(Boolean);
    const resolved = [];
    for (const part of parts) {
        if (part === '..') resolved.pop();
        else if (part !== '.') resolved.push(part);
    }
    return '/' + resolved.join('/');
}

/* گرفتن نود فایل‌سیستم در یک مسیر */
function getNode(path) {
    if (path === '/') return fileSystem;
    const parts = path.split('/').filter(Boolean);
    let node = fileSystem;
    for (const part of parts) {
        if (!node || node.type !== 'dir' || !node.children[part]) return null;
        node = node.children[part];
    }
    return node;
}

/* نمایش مسیر به شکل خلاصه (~ بجای /home/runner) */
function displayPath(cwd) {
    if (cwd === HOME || cwd === HOME + '/') return '~';
    if (cwd.startsWith(HOME + '/')) return '~' + cwd.slice(HOME.length);
    return cwd;
}

/* ساخت HTML پرامپت */
function getPrompt(tab) {
    const [user, host] = tab.name.split('@');
    const path = displayPath(tab.cwd);
    return `<span class="prompt-user">${escapeHtml(user)}</span><span class="prompt-sep">@</span><span class="prompt-host">${escapeHtml(host)}</span><span class="prompt-sep">:</span><span class="prompt-path">${escapeHtml(path)}</span><span class="prompt-dollar">$ </span>`;
}

/* ============================================================
   مدیریت تب‌ها
   ============================================================ */
function createTerminal(name) {
    tabCounter++;
    const id = tabCounter;
    terminals[id] = {
        id,
        name: name || `runner@ubuntu`,
        cwd: HOME,
        history: [],
        historyIndex: -1,
    };
    renderTabs();
    createScreen(id);
    switchTab(id);
    /* پیام خوش‌آمدگویی */
    const screen = document.querySelector(`.screen[data-id="${id}"]`);
    addWelcomeMessage(screen, id);
    return id;
}

function switchTab(id) {
    if (!terminals[id]) return;
    activeTabId = id;
    /* آپدیت نمایش تب‌ها */
    document.querySelectorAll('.tab').forEach(t => {
        t.classList.toggle('active', Number(t.dataset.id) === id);
    });
    /* آپدیت نمایش صفحات */
    document.querySelectorAll('.screen').forEach(s => {
        s.classList.toggle('active', Number(s.dataset.id) === id);
    });
    /* فوکوس روی اینپوت */
    const screen = document.querySelector(`.screen[data-id="${id}"]`);
    const input = screen?.querySelector('.input-field');
    if (input) input.focus();
    /* آپدیت نوار وضعیت */
    document.getElementById('statusCwd').textContent = displayPath(terminals[id].cwd);
}

function closeTab(id) {
    const ids = Object.keys(terminals).map(Number);
    if (ids.length <= 1) {
        /* آخرین تب — فقط پاک کن */
        const screen = document.querySelector(`.screen[data-id="${id}"]`);
        if (screen) screen.innerHTML = '';
        addOutputLines(screen, '<span class="dim-line">Connection closed.</span>', '');
        const il = screen.querySelector('.input-line');
        if (il) il.remove();
        return;
    }
    delete terminals[id];
    const tabEl = document.querySelector(`.tab[data-id="${id}"]`);
    const screenEl = document.querySelector(`.screen[data-id="${id}"]`);
    if (tabEl) tabEl.remove();
    if (screenEl) screenEl.remove();
    if (activeTabId === id) {
        const remaining = Object.keys(terminals).map(Number);
        switchTab(remaining[remaining.length - 1]);
    }
}

function renderTabs() {
    const bar = document.getElementById('tabBar');
    /* حذف تب‌های قدیمی (نه دکمه اضافه) */
    bar.querySelectorAll('.tab').forEach(t => t.remove());
    for (const id of Object.keys(terminals)) {
        const tab = terminals[id];
        const el = document.createElement('div');
        el.className = 'tab' + (Number(id) === activeTabId ? ' active' : '');
        el.dataset.id = id;
        el.innerHTML = `<i class="fas fa-terminal tab-icon"></i><span class="tab-name">${escapeHtml(tab.name)}</span><span class="tab-close">&times;</span>`;
        el.addEventListener('click', (e) => {
            if (e.target.classList.contains('tab-close')) {
                closeTab(Number(id));
            } else {
                switchTab(Number(id));
            }
        });
        bar.insertBefore(el, bar.querySelector('.add-tab-btn'));
    }
}

/* ============================================================
   مدیریت صفحه نمایش
   ============================================================ */
function createScreen(tabId) {
    const container = document.getElementById('screenContainer');
    const screen = document.createElement('div');
    screen.className = 'screen';
    screen.dataset.id = tabId;
    screen.addEventListener('click', () => {
        const inp = screen.querySelector('.input-field');
        if (inp) inp.focus();
    });
    container.appendChild(screen);
}

function createInputLine(screen, tabId) {
    const line = document.createElement('div');
    line.className = 'input-line';
    const prompt = document.createElement('span');
    prompt.innerHTML = getPrompt(terminals[tabId]);
    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'input-field';
    input.spellcheck = false;
    input.autocomplete = 'off';
    input.setAttribute('aria-label', 'Terminal input');
    input.addEventListener('keydown', (e) => handleKeyDown(e, tabId));
    line.appendChild(prompt);
    line.appendChild(input);
    screen.appendChild(line);
    requestAnimationFrame(() => input.focus());
}

function addOutputLines(screen, html, className) {
    const lines = html.split('\n');
    const inputLine = screen.querySelector('.input-line');
    lines.forEach(text => {
        const div = document.createElement('div');
        div.className = 'line ' + (className || 'output-line');
        div.innerHTML = text;
        screen.insertBefore(div, inputLine);
    });
}

function addWelcomeMessage(screen, tabId) {
    const now = new Date();
    const dateStr = now.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) + ' ' +
                    now.toLocaleTimeString('en-US', { hour12: false });
    const welcome = [
        `<span class="success-line">Welcome to Ubuntu 22.04.3 LTS (GNU/Linux 5.15.0-91-generic x86_64)</span>`,
        ``,
        ` <span class="info-line">Documentation:</span>  https://help.ubuntu.com`,
        ` <span class="info-line">Management:</span>     https://landscape.canonical.com`,
        ` <span class="info-line">Support:</span>        https://ubuntu.com/advantage`,
        ``,
        `  System information as of <span class="dim-line">${dateStr}</span>`,
        ``,
        `  System load:  <span class="dim-line">0.08</span>              Processes:             <span class="dim-line">128</span>`,
        `  Usage of /:   <span class="dim-line">9.2% of 483.08GB</span>  Users logged in:       <span class="dim-line">1</span>`,
        `  Memory usage: <span class="dim-line">8%</span>                IPv4 address for eth0: <span class="dim-line">192.168.1.105</span>`,
        `  Swap usage:   <span class="dim-line">0%</span>`,
        ``,
        `Last login: <span class="dim-line">${dateStr}</span> from <span class="dim-line">192.168.1.1</span>`,
        ``,
    ];
    addOutputLines(screen, welcome.join('\n'), '');
    createInputLine(screen, tabId);
    screen.scrollTop = screen.scrollHeight;
}

/* ============================================================
   پردازش دستورات
   ============================================================ */
function processCommand(input, tab) {
    const trimmed = input.trim();
    if (!trimmed) return '';

    const parts = trimmed.split(/\s+/);
    const cmd = parts[0].toLowerCase();
    const args = parts.slice(1);

    const handlers = {
        'ls':        () => handleLs(args, tab),
        'cd':        () => handleCd(args, tab),
        'pwd':       () => tab.cwd,
        'cat':       () => handleCat(args, tab),
